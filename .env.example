# Database — Railway sets DATABASE_URL automatically when you add a MySQL plugin.
# If present, it takes priority over the individual MYSQL_* vars below.
DATABASE_URL=mysql://user:password@host:port/database

# Local / fallback database config (used only when DATABASE_URL is unset)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=obd2logger

# Dashboard access PIN
DASHBOARD_PIN=7429

# Server port (Railway assigns this automatically)
PORT=3000
